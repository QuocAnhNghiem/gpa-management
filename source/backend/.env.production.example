NODE_ENV=production
PORT=5000
MONGO_URI=mongodb+srv://USER:PASSWORD@HOST/gpa-management
JWT_SECRET=replace-with-at-least-32-random-characters
FRONTEND_URL=https://your-web-domain.com
# Set for cross-subdomain frontend/API deployments, for example .example.com
COOKIE_DOMAIN=

# Set to false while Google OAuth is not configured yet. /api/auth/google will return 503.
GOOGLE_OAUTH_ENABLED=false
# Required when GOOGLE_OAUTH_ENABLED=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-api-domain.com/api/auth/google/callback

# Required if cron email alerts are enabled
EMAIL_USER=
EMAIL_PASS=

# Required for avatar/cover uploads
AWS_REGION=ap-southeast-1
S3_BUCKET_NAME=your-app-assets-bucket
# Optional alias used by IaC naming; S3_BUCKET_NAME takes precedence if both are set
S3_UPLOAD_BUCKET=your-app-assets-bucket
# Optional if you expose files through CloudFront or a custom domain
S3_PUBLIC_BASE_URL=
# Optional upload root prefix inside the bucket
S3_UPLOAD_PREFIX=uploads
# Optional presigned URL expiry in seconds. Keep short in production.
S3_PRESIGNED_URL_EXPIRES_IN=300

# Leave empty until the Chrome extension is published and you have its production ID
# CHROME_EXTENSION_ORIGIN=chrome-extension://aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
# CHROME_EXTENSION_ORIGINS=chrome-extension://aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa,chrome-extension://bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb

# Must stay unset/false in production
ENABLE_TEST_ROUTES=false
